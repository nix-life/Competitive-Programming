#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int s, n;
    cin >> s >> n;
    vector<pair<int, int>> dragons(n);
    for (int i = 0; i < n; i++) {
        cin >> dragons[i].first;
        cin >> dragons[i].second;
    }
    sort(dragons.begin(), dragons.end());
    bool can = true;
    for (int i = 0; i < n; i++) {
        if (s>dragons[i].first) s += dragons[i].second;
        else can = false;
    }
    if (can) cout << "YES\n";
    else cout << "NO\n";
    
    return 0;
}
