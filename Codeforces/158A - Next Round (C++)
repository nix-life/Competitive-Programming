#include <iostream>
#include <vector>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, k;
    cin >> n >> k;
    int total = 0;
    vector<int> s;

    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;
        s.push_back(x);
    }

    int cutoff = s[k-1];
    for (int i = 0; i < n; i++) {
        if (s[i] > 0 && s[i] >= cutoff) total++;
    }

    cout << total;
}
