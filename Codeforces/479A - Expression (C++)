#include <iostream>
#include <vector>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int a, b, c;
    cin >> a >> b >> c;

    int m = a+b+c;
    m = max(m, a*b*c);
    m = max(m, a*b+c);
    m = max(m, a+b*c);
    m = max(m, (a+b)*c);
    m = max(m, a*(b+c));

    cout << m;
}
