#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    string s;
    cin >> s;

    int u = 0, r = 0;
    int coins = 0;

    for (int i = 0; i < n; i++) {
        if (u == r && i > 0 && s[i] == s[i - 1]) {
            coins++;
        }
        if (s[i] == 'U') u++;
        else r++;
    }

    cout << coins << "\n";
    return 0;
}
