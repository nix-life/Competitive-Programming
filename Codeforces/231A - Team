#include <iostream>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    int total = 0;

    for (int i = 0; i < n; i++) {
        int s1, s2, s3;
        cin >> s1 >> s2 >> s3;

        int sure = s1 + s2 + s3;
        if (sure >= 2) total++;
    }
    cout << total;
}
