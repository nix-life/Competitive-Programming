#include <bits/stdc++.h>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int s, v1, v2, t1, t2;
    cin >> s >> v1 >> v2 >> t1 >> t2;
    int p1 = s*v1 + 2*t1;
    int p2 = s*v2 + 2*t2;
    if (p1 == p2) cout << "Friendship\n";
    else if (p1 < p2) cout << "First\n";
    else cout << "Second\n";
}
