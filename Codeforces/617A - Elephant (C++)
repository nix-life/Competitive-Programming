#include <iostream>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    int moves = 0;
    while (n > 0) {
        if (n-5 >= 0) {
            n-=5;
            moves++;
        } else {
            moves++;
            break;
        }
    }
    cout << moves;
}
