#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    string s;
    cin >> s;
    int n;
    cin >> n;
    bool first = false;
    bool second = false;
    for (int i = 0; i < n; i++) {
        string x;
        cin >> x;
        if (x == s) {
            first = true;
            second = true;
        }
        if (x[0] == s[1]) second = true;
        if (x[x.length()-1] == s[0]) first = true;
    }
    if (first && second) cout << "YES\n";
    else cout << "NO\n";
    return 0;
}
