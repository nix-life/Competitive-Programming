#include <iostream>
#include <vector>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    for (int i = 0; i < n; i++) {
        vector<int> x(7);
        for (int j = 0; j < 7; j++) {
            cin >> x[j];
        }
        sort(x.begin(), x.end());
        int sum = 0;
        for (int j = 0; j < 6; j++) {
            sum -= x[j];
        }
        sum+=x[x.size()-1];
        cout << sum << "\n";
    }
}
