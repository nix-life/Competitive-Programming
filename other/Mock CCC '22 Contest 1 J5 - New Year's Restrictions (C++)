#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int N, M;
    cin >> N >> M;

    vector<pair<int,int>> edges;
    for (int i = 0; i < M; i++) {
        int a, b;
        cin >> a >> b;
        --a; --b;
        edges.push_back({a, b});
    }

    int ans = 0;

    for (int mask = 0; mask < (1 << N); mask++) {
        bool valid = true;
        for (auto &[u, v] : edges) {
            if ((mask & (1 << u)) && (mask & (1 << v))) {
                valid = false;
                break;
            }
        }

        if (valid) {
            ans = max(ans, __builtin_popcount(mask));
        }
    }

    cout << ans << "\n";
    return 0;
}
