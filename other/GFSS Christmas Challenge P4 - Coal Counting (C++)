#include <bits/stdc++.h>
#include <cctype>

using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, m;
    cin >> n >> m;
    vector<int> v(n);

    for (int i = 0; i < n; i++) {
        cin >> v[i];
    } 
    for (int i = 0; i < m; i++) {
        int m;
        int total = 0;
        cin >> m;
        for (int j = 0; j < n; j++) {
            if (v[j] >= m) total++;
        }
        cout << total << "\n";
    }

    return 0;
}
