#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, W;
    cin >> n >> W;

    vector<long long> weight(n), value(n);
    for (int i = 0; i < n; i++) {
        cin >> weight[i] >> value[i];
    }

    vector<vector<long long>> dp(n + 1, vector<long long>(W + 1, 0));

    for (int i = 1; i <= n; i++) {
        for (int j = 0; j <= W; j++) {
            dp[i][j] = dp[i - 1][j];

            if (j >= weight[i - 1]) {
                dp[i][j] = max(
                    dp[i][j],
                    dp[i - 1][j - weight[i - 1]] + value[i - 1]
                );
            }
        }
    }

    cout << dp[n][W] << "\n";
    return 0;
}
