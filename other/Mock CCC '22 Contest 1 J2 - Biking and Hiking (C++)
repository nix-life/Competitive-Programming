#include <iostream>
#include <string>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;
    string s;
    cin >> s;

    int total = k;
    int num_walk = 0;
    bool walking = false;

    for (int i = 0; i < s.length(); i++) {

        if (walking) {
            if (s[i] == 'D') {
                walking = false;
                total = 1;
            } else {
                num_walk++;
            }
            continue;
        }

        if (s[i] == 'U') total--;
        else if (s[i] == 'D') total++;

        if (total == 0) {
            walking = true;
            num_walk++;
        }
    }

    cout << num_walk << "\n";
    return 0;
}
