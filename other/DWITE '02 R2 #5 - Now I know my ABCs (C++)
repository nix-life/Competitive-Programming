#include <bits/stdc++.h>
#include <cctype>

using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    for (int i = 0; i < 5; i++) {
        string s;
        getline(cin, s); 
        transform(s.begin(), s.end(), s.begin(), ::toupper);
        unordered_map<char, int> x;
        for (char& j : s) {
            if (isalpha(j)) {
                x[j]+=1;
            }
        }
        string check = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        bool first = true;
        for (char& j : check) {
            if (x[j] != 0) {
                if (!first) cout << ":";
                cout << j << "-" << x[j];
                first = false;
            }
        }
        cout << endl;
    }
    return 0;
}
