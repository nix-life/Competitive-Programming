#include <iostream>
#include <vector>
#include <functional>
#include <algorithm>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> x(n);
    for (int i = 0; i < n; i++) {
        cin >> x[i];
    }

    sort(x.begin(), x.end(), greater<int>());
    int max1 = 0;
    int max2 = 0;

    for (int i = 0; i < n; i++) {
        if (x[i] > 100) continue;
        else if (x[i] > max1) max1 = x[i];
        else if (x[i] > max2) max2 = x[i];
    }

    cout << max1+max2;

    return 0;
}
