#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    cin.ignore();

    int low = 1, high = n;

    while (true) {
        int mid = low + (high - low) / 2;
        cout << mid << '\n' << flush;

        string s;
        getline(cin, s);

        if (s == "just right") break;
        else if (s == "too low") low = mid + 1;
        else if (s == "too high") high = mid - 1;
    }
    return 0;
}
