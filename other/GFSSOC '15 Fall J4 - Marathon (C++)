#include <bits/stdc++.h>

using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, q;
    cin >> n >> q;
    vector<int> x(n);
    int total = 0;
    for (int i = 0; i < n; i++) {
        cin >> x[i];
        total += x[i];
    }
    vector<long long> pref(n + 1, 0);
    for (int i = 0; i < n; i++) {
        pref[i + 1] = pref[i] + x[i];
    }
    for (int i = 0; i < q; i++) {
        int a, b;
        cin >> a >> b;
       long long sum = pref[b] - pref[a - 1];
        cout << total - sum << "\n";
    }

    return 0;
}
