#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    for (int i = 0; i < n; i++) {
        pair<double, double> a, b, c;
        cin >> a.first >> a.second;
        cin >> b.first >> b.second;
        cin >> c.first >> c.second;

        double len_1 = sqrt(pow(a.first-b.first, 2) + pow(a.second-b.second, 2));
        double len_2 = sqrt(pow(a.first-c.first, 2) + pow(a.second-c.second, 2));
        double len_3 = sqrt(pow(b.first-c.first, 2) + pow(b.second-c.second, 2));

        double p = len_1+len_2+len_3;
        double s = p/2;
        cout << std::fixed << std::setprecision(2) << sqrt(s*(s-len_1)*(s-len_2)*(s-len_3)) << " " << p << "\n";
    }

    return 0;
}
