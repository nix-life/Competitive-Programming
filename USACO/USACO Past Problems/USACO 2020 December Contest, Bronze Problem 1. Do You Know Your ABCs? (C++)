#include <bits/stdc++.h>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    vector<int> x(7);
    for (int i = 0; i < 7; i++) {
        cin >> x[i];
    }
    sort(x.begin(), x.end());
    int a = x[0];
    int b = x[1];
    int c = x[6] - a - b;
    cout << a << " " << b << " " << c << "\n";
    return 0;
}
