#include <bits/stdc++.h>
using namespace std;

void pour(int& c1, int& m1, int& c2, int& m2) {
    int num = min(m1, c2 - m2);
    m1 -= num;
    m2 += num;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    ifstream fin("mixmilk.in");
    ofstream fout("mixmilk.out");

    int c1, m1, c2, m2, c3, m3;
    fin >> c1 >> m1 >> c2 >> m2 >> c3 >> m3;

    for (int i = 0; i < 33; i++) {
        pour(c1, m1, c2, m2);
        pour(c2, m2, c3, m3);
        pour(c3, m3, c1, m1);
    }
    pour(c1, m1, c2, m2);

    fout << m1 << "\n" << m2 << "\n" << m3 << "\n";
    return 0;
}
