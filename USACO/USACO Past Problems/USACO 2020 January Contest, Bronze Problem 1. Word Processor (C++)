#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    ifstream fin("word.in");
    ofstream fout("word.out");

    int n, k;
    fin >> n >> k;

    int current = 0;
    string s;

    for (int i = 0; i < n; i++) {
        fin >> s;
        if (current + s.length() > k) {
            fout << "\n";
            fout << s;
            current = s.length();
        } else {
            if (current > 0) fout << " ";
            fout << s;
            current += s.length();
        }
    }

    return 0;
}
