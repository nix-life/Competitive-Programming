    ifstream fin ("friday.in");

    int N;
    fin >> N;

    vector<int> count(7, 0);

    int dayOfWeek = 2;

    for (int year = 1900; year < 1900 + N; year++) {
        for (int month = 1; month <= 12; month++) {
            int days = daysInMonth(month, year);

            for (int day = 1; day <= days; day++) {
                if (day == 13) {
                    count[dayOfWeek]++;
                }
                dayOfWeek = (dayOfWeek + 1) % 7;
            }
        }
    }

    for (int i = 0; i < 7; i++) {
        if (i > 0) fout << " ";
        fout << count[i];
    }
    fout << endl;

    return 0;
}
