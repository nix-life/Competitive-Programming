#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    vector<int> x(5, 0);
    for (int i = 0; i < n; i++) {
        string s;
        cin >> s;
        for (int j = 0; j < 5; j++) {
            if (s[j] == 'Y') x[j]++;
        }
    }
    int m = ranges::max(x);
    string s;
    for (int i = 0; i < 5; i++) {
        if (x[i] == m) s+="," + to_string(i+1); 
    }
    cout << s.substr(1, s.length());
}
