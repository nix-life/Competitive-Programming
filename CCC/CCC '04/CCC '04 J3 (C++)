#include <iostream>
#include <string>
#include <vector>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;
    vector<string> s(n);
    vector<string> x(m);

    for (int i = 0; i < n; i++) {
        cin >> s[i];
    }

    for (int i = 0; i < m; i++) {
        cin >> x[i];
    }

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) cout << s[i] << " as " << x[j] << "\n"; 
    }

    return 0;
}
