#include <bits/stdc++.h>
using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    int m = INT_MAX;
    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;
        int temp = 0;
        while (x%2==0) {
            x/=2;
            temp++;
        }
        m = min(temp, m);
    }
    cout << m;
}
