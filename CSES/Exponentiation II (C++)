#include <bits/stdc++.h>
using namespace std;

const long long MOD = 1000000007;
const long long MOD_EXP = MOD - 1;

long long modpow(long long a, long long b, long long mod) {
    long long res = 1;
    a %= mod;
    while (b > 0) {
        if (b & 1) res = res * a % mod;
        a = a * a % mod;
        b >>= 1;
    }
    return res;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    for (int i = 0; i < n; i++) {
        long long a, b, c;
        cin >> a >> b >> c;

        long long exp = modpow(b, c, MOD_EXP);
        cout << modpow(a, exp, MOD) << "\n";
    }

    return 0;
}
