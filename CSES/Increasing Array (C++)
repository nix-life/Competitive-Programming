#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
	ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;
    long long total_moves = 0;
    vector<long long> s;
    
    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;
        s.push_back(x);
    }

    for (int i = 1; i < n; i++) {
        if (s[i]<s[i-1]) {
            total_moves += (s[i-1]-s[i]);
            s[i] += (s[i-1]-s[i]);
        }
    }

    cout << total_moves;
}
